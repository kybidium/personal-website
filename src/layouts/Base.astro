---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Personal site of Luis Ojeda." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <a class="wordmark" href="/">
          <svg class="leaf" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M20 4C12 4 5 8 4 17c-.1 1 .3 2.4 1 3 .6-4 2.5-8.5 7-11-3.5 3.5-5.5 7.5-6 11 1 .5 2.5.6 4 .4C18 19 21 12 20 4Z"
              fill="currentColor"
            />
          </svg>
          Luis Ojeda
        </a>
        <nav>
          <a href="/" class:list={{ active: Astro.url.pathname === "/" }}>Home</a>
          <a
            href="/blog"
            class:list={{ active: Astro.url.pathname.startsWith("/blog") }}
            >Blog</a
          >
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <span class="vine" aria-hidden="true">❧</span>
        <p>© {new Date().getFullYear()} Luis Ojeda</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f5f4ec;
    --bg-raised: #fbfaf5;
    --ink: #232d1f;
    --ink-soft: #5c6653;
    --green: #35682d;
    --green-deep: #274d21;
    --green-tint: #e3ead9;
    --line: #d8dcc9;
    --serif: "Fraunces", Georgia, serif;
    --sans: "Inter", system-ui, sans-serif;
  }

  * {
    margin: 0;
    box-sizing: border-box;
  }

  html {
    color-scheme: light;
  }

  body {
    font-family: var(--sans);
    background: var(--bg);
    background-image: radial-gradient(
        circle at 85% -10%,
        rgba(53, 104, 45, 0.08),
        transparent 45%
      ),
      radial-gradient(circle at -10% 100%, rgba(53, 104, 45, 0.06), transparent 40%);
    color: var(--ink);
    line-height: 1.65;
    min-height: 100vh;
  }

  h1,
  h2,
  h3 {
    font-family: var(--serif);
    font-weight: 500;
    line-height: 1.2;
    color: var(--green-deep);
  }

  a {
    color: var(--green);
  }

  .page {
    max-width: 42rem;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 3rem;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0 2.5rem;
    gap: 1rem;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--green-deep);
    text-decoration: none;
  }

  .leaf {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--green);
  }

  .site-header nav {
    display: flex;
    gap: 1.25rem;
  }

  .site-header nav a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
  }

  .site-header nav a:hover {
    color: var(--green);
  }

  .site-header nav a.active {
    color: var(--green-deep);
    border-bottom-color: var(--green);
  }

  .site-footer {
    padding-top: 3rem;
    text-align: center;
    color: var(--ink-soft);
    font-size: 0.85rem;
  }

  .vine {
    display: block;
    color: var(--green);
    font-size: 1.3rem;
    margin-bottom: 0.25rem;
  }
</style>
